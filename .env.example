CLOUDBASE_ENV_ID=
CLOUDBASE_REGION=ap-shanghai

# auto: 有 session token 就走临时凭证；没有就走长期密钥
# long-lived: 只使用长期 SecretId/SecretKey，忽略临时 token
# temporary: 只使用临时凭证，只适合临时排障
CLOUDBASE_CREDENTIAL_MODE=long-lived

# 长期稳定方案请配置下面两项
CLOUDBASE_SECRET_ID=
CLOUDBASE_SECRET_KEY=

# 仅临时调试时使用
CLOUDBASE_SESSION_TOKEN=

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_SESSION_SECRET=seat-admin-secret

ARK_API_KEY=
ARK_VISION_MODEL=
ARK_BASE_URL=
